---
import {type CollectionEntry, getCollection} from "astro:content";

import RootLayout from "@/layouts/RootLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Techno from "@/components/Techno.astro";
import Link from "@/components/Link.astro";
import { useTranslations } from "@/i18n";

const t = useTranslations();

const technos = await getCollection('technos');
const posts = await getCollection('blog');

function technoCount(id: CollectionEntry<"technos">["id"]) {
  if (!posts) return 0;
  return posts.filter((post) => post.data.technos.some((ref) => ref.id === id)).length;
}
---
<RootLayout title={t('pages.technos.title')} description={t('pages.technos.description')}>
    <div class="flex flex-col items-start justify-start divide-y divide-gray-200 dark:divide-gray-700 md:mt-24 md:flex-row md:items-center md:justify-center md:space-x-6 md:divide-y-0">
        <div class="space-x-2 pb-8 pt-6 md:space-y-5">
            <Breadcrumbs items={[{ label: t("nav.home"), href: "/" }, { label: t("nav.technos") }]} />
            <h1 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:border-r-2 md:px-6 md:text-6xl md:leading-14">
                {t('pages.technos.allTechnos')}
            </h1>
        </div>
        <div class="flex max-w-lg flex-wrap">
            {!technos.length && t('pages.technos.noTechnos')}
            {technos.map((techno) => {
                return (
                        <div class="mb-2 mr-5 mt-2">
                            <Techno techno={techno}/>
                            <Link href={`/technos/${techno.id}`}
                                  class="-ml-2 text-sm font-semibold uppercase text-gray-600 dark:text-gray-300"
                                  aria-label={t('pages.technos.viewPosts', {techno: techno.data.name})}>
                                {` (${technoCount(techno.id)})`}
                            </Link>
                        </div>
                )
            })}
        </div>
    </div>
</RootLayout>
