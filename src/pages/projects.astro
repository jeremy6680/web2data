---
import Card from "@/components/Card.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { useTranslations } from "@/i18n";
import RootLayout from "@/layouts/RootLayout.astro";

// Import images from src/assets/ — Astro will optimize them at build time
import project1Img from "@/assets/project-1.png";
import project2Img from "@/assets/project-2.png";
import project3Img from "@/assets/project-3.png";

const t = useTranslations();

const projectsData = [
  {
    title: "Running Performance Analyzer",
    description: `Une plateforme d'analyse basée sur l'IA pour les coureurs`,
    imgSrc: project1Img, // ImageMetadata object, not a string
    href: "https://github.com/jeremy6680/running-performance-analyzer",
  },
  {
    title: "SpotifAI",
    description: `Générateur de playlists Spotify personnalisées via LLM`,
    imgSrc: project2Img,
    href: "https://github.com/jeremy6680/spotifai",
  },
  {
    title: "Sports Cards Inventory",
    description: `Une application web basée sur Python`,
    imgSrc: project3Img,
    href: "https://github.com/jeremy6680/sports-cards-inventory",
  },
];
---

<RootLayout
  title={t("pages.projects.title")}
  description={t("pages.projects.description")}
>
  <div class="divide-y divide-gray-200 dark:divide-gray-700">
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <Breadcrumbs items={[{ label: t("nav.home"), href: "/" }, { label: t("nav.projects") }]} />
      <h1
        class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14"
      >
        {t("pages.projects.allProjects")}
      </h1>
      <p class="text-lg leading-7 text-gray-500 dark:text-gray-400">
        {t("pages.projects.showcase")}
      </p>
    </div>
    <div class="container py-12">
      <div class="-m-4 flex flex-wrap">
        {
          projectsData.map((d) => (
            <Card
              title={d.title}
              description={d.description}
              imgSrc={d.imgSrc}
              href={d.href}
            />
          ))
        }
      </div>
    </div>
  </div>
</RootLayout>
