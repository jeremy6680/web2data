---
import Link from "./Link.astro";
import { type CollectionEntry, getEntry } from "astro:content";

interface Props {
  domaine?: CollectionEntry<"domaines">;
  slug?: string;
}

let DomaineProp = Astro.props.domaine;

if (!DomaineProp && Astro.props.slug) {
  DomaineProp = await getEntry("domaines", Astro.props.slug);
}
---

{DomaineProp && (
  <Link
    href={`/domaines/${DomaineProp.id}`}
    class="mr-3 text-sm font-medium uppercase hover:opacity-80"
    style="color: #5B3DF5"
  >
    {DomaineProp.data.name}
  </Link>
)}
