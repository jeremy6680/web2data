---
import { Image } from "astro:assets";
import Link from "./Link.astro";
import { useTranslations } from "@/i18n";

const t = useTranslations();

interface Props {
  title: string;
  description: string;
  // Accept both imported image objects (src/assets/) and plain strings (public/)
  imgSrc?: string | ImageMetadata;
  href?: string;
}

const { title, description, imgSrc, href } = Astro.props;
---

<div class="md max-w-[544px] p-4 md:w-1/2">
  <div
    class:list={`${imgSrc && "h-full"} overflow-hidden rounded-md border-2 border-gray-200 border-opacity-60 dark:border-gray-700`}
  >
    {
      imgSrc &&
        (href ? (
          <Link href={href} aria-label={t('components.card.linkToPost', { title })}>
            {typeof imgSrc === "string" ? (
              // Plain string path — image lives in public/, no optimization
              <img
                alt={title}
                src={imgSrc}
                class="object-cover object-center md:h-36 lg:h-48 w-full"
                width={544}
                height={306}
                loading="lazy"
                decoding="async"
              />
            ) : (
              // Imported ImageMetadata — Astro optimizes, converts to WebP, generates srcset
              <Image
                alt={title}
                src={imgSrc}
                class="object-cover object-center md:h-36 lg:h-48"
                width={544}
                height={306}
              />
            )}
          </Link>
        ) : (
          typeof imgSrc === "string" ? (
            <img
              alt={title}
              src={imgSrc}
              class="object-cover object-center md:h-36 lg:h-48 w-full"
              width={544}
              height={306}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Image
              alt={title}
              src={imgSrc}
              class="object-cover object-center md:h-36 lg:h-48"
              width={544}
              height={306}
            />
          )
        ))
    }
    <div class="p-6">
      <h2 class="mb-3 text-2xl font-bold leading-8 tracking-tight">
        {
          href ? (
            <Link href={href} aria-label={t('components.card.linkToPost', { title })}>
              {title}
            </Link>
          ) : (
            title
          )
        }
      </h2>
      <p class="prose mb-3 max-w-none text-gray-500 dark:text-gray-400">
        {description}
      </p>
      {
        href && (
          <Link
            href={href}
            class="text-base font-medium leading-6 text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
            aria-label={t('components.card.linkToPost', { title })}
          >
            En savoir plus &rarr;
          </Link>
        )
      }
    </div>
  </div>
</div>